{
  "name": "synchro",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' --parallel dev",
    "build": "bun run --filter @synchro/frontend build",
    "db:generate": "cd apps/backend && bunx prisma generate",
    "db:push": "cd apps/backend && bunx prisma db push",
    "db:migrate": "cd apps/backend && bunx prisma migrate dev",
    "db:studio": "cd apps/backend && bunx prisma studio"
  }
}
